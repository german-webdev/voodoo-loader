{
  "name": "voodoo-loader",
  "private": true,
  "version": "0.2.0-alpha",
  "type": "module",
  "scripts": {
    "dev": "webpack serve --mode development --config webpack.config.cjs --hot",
    "build": "npm run typecheck && webpack --mode production --config webpack.config.cjs",
    "build:analyze": "cross-env BUNDLE_ANALYZE=1 npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "check:fsd": "node ./scripts/check-fsd-boundaries.cjs",
    "check": "npm run lint && npm run typecheck && npm run check:fsd && npm run test",
    "check:frontend:ci": "npm run check && npm run build && npm run storybook:build && npx playwright install chromium && npm run e2e",
    "check:rust": "node ./scripts/run-rust-checks.cjs",
    "check:prepush": "npm run check:frontend:ci && npm run check:rust",
    "release:portable": "node ./scripts/release-portable.cjs",
    "prepare": "cd .. && npx husky VoodooLoader.Tauri/.husky",
    "preview": "serve dist -l 4173",
    "tauri": "tauri"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.0.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "formik": "^2.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-redux": "^9.2.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@playwright/test": "^1.56.1",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react-webpack5": "^8.6.14",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "compression-webpack-plugin": "^12.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-testing-library": "^7.13.3",
    "html-webpack-plugin": "^5.6.4",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.2.4",
    "prettier": "^3.6.2",
    "serve": "^14.2.5",
    "storybook": "^8.6.14",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.46.1",
    "webpack": "^5.102.1",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ],
    "*.{json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  }
}
