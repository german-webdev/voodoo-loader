{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voodoo Loader",
  "version": "0.2.0",
  "identifier": "com.voodooloader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Voodoo Loader",
        "width": 1160,
        "height": 760,
        "minWidth": 980,
        "minHeight": 680,
        "maxWidth": 1920,
        "maxHeight": 1440
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
